rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Basic catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isAdmin() {
      return isSignedIn() && getUserData().role == 'admin';
    }

    // User profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && 
                      request.resource.data.keys().hasAll(['uid', 'email', 'role', 'createdAt']) &&
                      (request.resource.data.role == 'user' || request.auth.token.email == 'nikhilchauhan0010@gmail.com');
      allow update: if isOwner(userId) && 
                      request.resource.data.role == resource.data.role; // Prevent self-promotion
    }

    // Products
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
      
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      }
    }

    // Categories
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders
    match /orders/{orderId} {
      allow read: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow update: if isAdmin();
    }
  }
}
